<%- include('partials/_header') %>

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="text-center p-5 bg-white shadow rounded-4 w-100" style="max-width: 600px;">
        <i class="bi bi-heartbreak-fill display-1 text-danger mb-4 d-block" style="animation: pulse 2s infinite;"></i>
        
        <h1 class="display-3 fw-bold text-dark mb-2">404</h1>
        <h3 class="h4 text-muted mb-4">Page Not Found</h3>
        
        <p class="text-secondary mb-5 px-md-4">
            It looks like this link is a broken capillary! The page you are looking for has been moved, deleted, or possibly never existed.
        </p>
        
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a href="/" class="btn btn-danger btn-lg rounded-pill shadow-sm px-4">
                <i class="bi bi-house-door-fill me-2"></i> Return to Homepage
            </a>
            <a href="javascript:history.back()" class="btn btn-outline-secondary btn-lg rounded-pill px-4">
                <i class="bi bi-arrow-left me-2"></i> Go Back
            </a>
        </div>
    </div>
</div>

<style>
@keyframes pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.1); color: #dc3545; }
    100% { transform: scale(1); }
}
</style>

<%- include('partials/_footer') %>