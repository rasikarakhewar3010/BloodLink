<%- include('../partials/_header') %>

<div class="container-fluid my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Admin Dashboard</h1>
        <a href="/admin/logout" class="btn btn-warning"><i class="bi bi-box-arrow-right"></i> Admin Logout</a>
    </div>

    <%- include('../partials/_messages') %>

    <div class="row">
        <!-- Add New Doctor Form -->
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-person-plus-fill me-2"></i>Provision New Doctor</h4>
                </div>
                <div class="card-body">
                    <form action="/admin/create-doctor" method="POST">
                        <div class="mb-3">
                            <label for="username" class="form-label fw-bold">Username</label>
                            <input type="text" id="username" name="username" class="form-control" value="<%= typeof username != 'undefined' ? username : '' %>" required>
                            <small class="text-muted">Will be used for doctor login</small>
                        </div>
                        <div class="mb-3">
                            <label for="password" class="form-label fw-bold">Password</label>
                            <div class="input-group">
                                <input type="password" id="password" name="password" class="form-control" required>
                                <button class="btn btn-outline-secondary toggle-password" type="button" data-target="password">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="password2" class="form-label fw-bold">Confirm Password</label>
                            <div class="input-group">
                                <input type="password" id="password2" name="password2" class="form-control" required>
                                <button class="btn btn-outline-secondary toggle-password" type="button" data-target="password2">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="city" class="form-label fw-bold">Assigned City Access</label>
                            <input type="text" id="city" name="city" class="form-control" value="<%= typeof city != 'undefined' ? city : '' %>" placeholder="e.g., Pune" required>
                            <small class="form-text text-muted">A doctor can <strong>only</strong> view, verify, and update donors mapped to this specific city.</small>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 mt-2">Create Doctor Profile</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Doctors List Table -->
        <div class="col-lg-8 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0"><i class="bi bi-people-fill me-2"></i>Active Doctor Accounts (<%= doctors ? doctors.length : 0 %>)</h4>
                </div>
                <div class="card-body p-0">
                    <% if (doctors && doctors.length > 0) { %>
                        <div class="table-responsive">
                            <table class="table table-hover table-bordered mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Username</th>
                                        <th>Assigned City</th>
                                        <th>Generated Email (Auth)</th>
                                        <th>Created At</th>
                                        <th class="text-center">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% doctors.forEach(doctor => { %>
                                        <tr>
                                            <td class="fw-bold text-primary">Dr. <%= doctor.username %></td>
                                            <td><span class="badge bg-info text-dark" style="font-size:0.9em"><%= doctor.city %></span></td>
                                            <td class="text-muted"><small><%= doctor.username.replace(/\s+/g, '').toLowerCase() %>@bloodlink.app</small></td>
                                            <td><%= new Date(doctor.created_at).toLocaleDateString() %></td>
                                            <td class="text-center">
                                                <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteDocModal<%= doctor.id %>" title="Revoke Access">
                                                    <i class="bi bi-trash-fill"></i> Delete
                                                </button>

                                                <!-- Delete Confirmation Modal -->
                                                <div class="modal fade text-start" id="deleteDocModal<%= doctor.id %>" tabindex="-1" aria-labelledby="deleteLabel<%= doctor.id %>" aria-hidden="true">
                                                    <div class="modal-dialog">
                                                        <div class="modal-content">
                                                            <div class="modal-header bg-danger text-white">
                                                                <h1 class="modal-title fs-5" id="deleteLabel<%= doctor.id %>">Confirm Revocation</h1>
                                                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                                            </div>
                                                            <div class="modal-body">
                                                                <p>Are you absolutely sure you want to permanently delete the doctor account for <strong>Dr. <%= doctor.username %></strong>?</p>
                                                                <p class="text-danger"><small><i class="bi bi-exclamation-triangle-fill"></i> This will immediately terminate their active session and remove their permissions for the assigned city (<strong><%= doctor.city %></strong>).</small></p>
                                                            </div>
                                                            <div class="modal-footer">
                                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                                <form action="/admin/delete-doctor/<%= doctor.id %>" method="POST" class="m-0">
                                                                    <button type="submit" class="btn btn-danger">Yes, Delete Doctor</button>
                                                                </form>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <div class="p-5 text-center text-muted">
                            <i class="bi bi-person-x display-4 mb-3"></i>
                            <p class="lead">No doctor accounts have been provisioned yet.</p>
                            <p>Use the form on the left to create the first City Administrator.</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('click', function(e) {
        const toggleBtn = e.target.closest('.toggle-password');
        if (toggleBtn) {
            const inputId = toggleBtn.getAttribute('data-target');
            const passwordInput = document.getElementById(inputId);
            const icon = toggleBtn.querySelector('i');
            
            if (passwordInput && passwordInput.type === 'password') {
                passwordInput.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else if (passwordInput) {
                passwordInput.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        }
    });
</script>

<%- include('../partials/_footer') %>